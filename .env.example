CODEPILOT_ENV=local
CODEPILOT_STORAGE_DIR=storage
CODEPILOT_API_KEY=
CODEPILOT_MAX_INDEX_FILE_SIZE=512000
CODEPILOT_IGNORED_DIRS=.git,.idea,.venv,__pycache__,node_modules,dist,build,target,.pytest_cache,.ruff_cache
CODEPILOT_DATABASE_URL=postgresql+psycopg://codepilot:codepilot@localhost:5432/codepilot
CODEPILOT_REDIS_URL=redis://localhost:6379/0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
